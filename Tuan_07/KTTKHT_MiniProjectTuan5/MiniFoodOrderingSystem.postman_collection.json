				{
					"name": "Get All Notifications",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notifications",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notifications"]
						}
					},
					"response": []
				}
			]
		}
	]
}
